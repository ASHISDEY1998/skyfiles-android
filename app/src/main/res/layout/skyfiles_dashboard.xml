<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/skyfilesDashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- WELCOME HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnDrawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/menu_icon_control_normal_24dp"
                app:tint="#FFFFFF"
                android:padding="8dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/btnDrawer"
                android:layout_toStartOf="@id/layoutHeaderButtons"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SkyFiles"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your files, storage and favorites in one place"
                    android:textColor="#A0A0A0"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutHeaderButtons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/search_icon_control_normal_24dp"
                    app:tint="#FFFFFF"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btnSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/settings_icon_white_24dp"
                    app:tint="#FFFFFF"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </RelativeLayout>

        <!-- STORAGE OVERVIEW CENTERPIECE -->
        <LinearLayout
            android:id="@+id/cardStorageOverview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/skyfiles_card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:alpha="0"
            android:translationY="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FREE SPACE"
                android:textColor="#A0A0A0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/txtFreeSpaceLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Computing..."
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <ProgressBar
                android:id="@+id/progressStorageCenter"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/skyfiles_progress_drawable"
                android:layout_marginBottom="16dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2">

                <!-- Used stats -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtUsedSpace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 GB Used"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txtUsedPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% Used"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Total stats -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/txtTotalSpace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 GB Total"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txtFreePercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100% Free"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp" />
                </LinearLayout>
            </GridLayout>

            <!-- SD Card Stats Container (Hidden by default, shown dynamically) -->
            <LinearLayout
                android:id="@+id/containerSdCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#2C2C2E"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SD CARD FREE SPACE"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/txtSdFreeSpaceLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Computing..."
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/progressSdStorageCenter"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressDrawable="@drawable/skyfiles_progress_drawable"
                    android:layout_marginBottom="16dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="1">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtSdUsedSpace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 GB Used"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:id="@+id/txtSdTotalSpace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 GB Total"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </GridLayout>
            </LinearLayout>

            <!-- Network Storage Summary (Always visible) -->
            <LinearLayout
                android:id="@+id/containerNetworkStorage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#2C2C2E"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NETWORK STORAGE SUMMARY"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="1">

                    <!-- Saved servers -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtSavedServers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Saved Profiles"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Connected servers -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:id="@+id/txtConnectedServers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Active Connections"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </GridLayout>

                <TextView
                    android:id="@+id/txtLastConnectedServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last connected: None"
                    android:textColor="#A0A0A0"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- CONTINUE WATCHING CARD -->
        <TextView
            android:id="@+id/lblContinueWatching"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue Watching"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/cardContinueWatching"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/skyfiles_card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/listContinueWatching"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- LOCATIONS SECTION (GRID) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Locations"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <GridLayout
            android:id="@+id/gridLocations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="@integer/skyfiles_locations_columns"
            android:alignmentMode="alignBounds"
            android:columnOrderPreserved="false"
            android:layout_marginBottom="24dp"
            android:alpha="0"
            android:translationY="20dp">

            <!-- Card: Phone Storage -->
            <LinearLayout
                android:id="@+id/btnPhoneStorage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/skyfiles_ripple"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/device_icon_white_24dp"
                    app:tint="#0A84FF"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Storage"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card: Downloads -->
            <LinearLayout
                android:id="@+id/btnDownloads"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/skyfiles_ripple"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/download_icon_white_24dp"
                    app:tint="#0A84FF"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Downloads"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card: Pictures -->
            <LinearLayout
                android:id="@+id/btnPictures"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/skyfiles_ripple"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/image_icon_white_24dp"
                    app:tint="#0A84FF"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pictures"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card: Videos -->
            <LinearLayout
                android:id="@+id/btnVideos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/skyfiles_ripple"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/video_icon_white_24dp"
                    app:tint="#0A84FF"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Videos"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card: Documents -->
            <LinearLayout
                android:id="@+id/btnDocuments"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/skyfiles_ripple"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/document_icon_white_24dp"
                    app:tint="#0A84FF"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Documents"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card: Audio -->
            <LinearLayout
                android:id="@+id/btnAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/skyfiles_ripple"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/audio_icon_white_24dp"
                    app:tint="#0A84FF"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card: Network Storage -->
            <LinearLayout
                android:id="@+id/btnNetworkStorage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/skyfiles_ripple"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/shared_directory_icon_white_24dp"
                    app:tint="#0A84FF"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Network Storage"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <!-- FAVORITES CARD -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Favorites"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/cardFavorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/skyfiles_card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:alpha="0"
            android:translationY="20dp">

            <TextView
                android:id="@+id/txtFavCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No favorites yet"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtRecentFavName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bookmark folders to view them here."
                android:textColor="#A0A0A0"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- RECENT FILES CARD -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Files"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/cardRecents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/skyfiles_card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:alpha="0"
            android:translationY="20dp">

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmptyRecents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No recent files"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Files you've opened recently will appear here."
                    android:textColor="#A0A0A0"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Dynamic Recents List -->
            <LinearLayout
                android:id="@+id/listRecents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
